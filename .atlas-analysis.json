  "keyFeatures": [
    "SP-initiated and IdP-initiated SSO authentication flows",
    "Single Logout (SLO) support — both SP-initiated and IdP-initiated",
    "IdP metadata parsing from XML or remote URL",
    "XML signature verification and SAML assertion decryption (EncryptedAssertion)",
    "SP metadata generation with optional digital signature",
    "Multi-certificate support for key rollover and separate signing/encryption keys",
    "Replay attack prevention via assertion ID tracking",
    "Support for Ruby MRI 2.1+, JRuby 9.1+, and TruffleRuby"
  ],
  "publicApiSurface": [
